{
    "name": "psc-acme/registry-cart",
    "description": "Package registry-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\RegistryCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/console": "^7.0",
        "league/flysystem": "^3.0",
        "psr/log": "^3.0",
        "symfony/event-dispatcher": "^7.0",
        "carbon/carbon": "^3.0",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}